#!/bin/bash
RED='\033[31m'; GREEN='\033[32m'; YELLOW='\033[33m'; BLUE='\033[34m'; NC='\033[0m'

if ! command -v bc &> /dev/null; then
    apt install bc -y >/dev/null 2>&1 || yum install bc -y >/dev/null 2>&1
fi

echo -e "${BLUE}=========================================${NC}"
echo -e "${BLUE}   🧠 VPS 专业评分引擎 v5.2        ${NC}"
echo -e "${BLUE}   新增：出站带宽测速（speedtest）  ${NC}"
echo -e "${BLUE}=========================================${NC}"

echo -e "\n${YELLOW}📟 [1/7] CPU 性能检测...${NC}"
if ! command -v sysbench &> /dev/null; then
    apt install sysbench -y >/dev/null 2>&1 || yum install sysbench -y >/dev/null 2>&1
fi
sysbench cpu --threads=1 --time=5 run > /tmp/cpu_single.log 2>&1
single_score=$(grep "events per second:" /tmp/cpu_single.log | awk '{print $4}' | cut -d. -f1)
cores=$(nproc)
sysbench cpu --threads=$cores --time=5 run > /tmp/cpu_multi.log 2>&1
multi_score=$(grep "events per second:" /tmp/cpu_multi.log | awk '{print $4}' | cut -d. -f1)
[[ -z "$single_score" || "$single_score" == "0" ]] && single_score=800
[[ -z "$multi_score" || "$multi_score" == "0" ]] && multi_score=$((single_score * cores / 2))
if [[ $single_score -ge 1500 ]]; then sg=10; elif [[ $single_score -ge 1200 ]]; then sg=9; elif [[ $single_score -ge 900 ]]; then sg=7; elif [[ $single_score -ge 600 ]]; then sg=5; else sg=3; fi
ratio=$(echo "scale=2; $multi_score / $single_score" | bc)
if (( $(echo "$ratio >= 3.5" | bc -l) )); then mg=10; elif (( $(echo "$ratio >= 2.5" | bc -l) )); then mg=8; elif (( $(echo "$ratio >= 1.8" | bc -l) )); then mg=6; else mg=4; fi
cpu_score=$(echo "scale=1; $sg * 0.6 + $mg * 0.4" | bc)
echo -e "   单核: ${single_score}分 | 多核: ${multi_score}分 (${cores}核) -> ${cpu_score}/10"

echo -e "\n${YELLOW}💾 [2/7] 磁盘性能检测...${NC}"
if ! command -v fio &> /dev/null; then
    apt install fio -y >/dev/null 2>&1 || yum install fio -y >/dev/null 2>&1
fi
fio --name=4k_read --directory=/tmp --size=128M --bs=4k --rw=randread --ioengine=libaio --direct=1 --numjobs=1 --iodepth=32 --time_based --runtime=6 --group_reporting > /tmp/fio.log 2>&1
iops=$(grep -oP 'iops=\K[0-9]+' /tmp/fio.log | head -1)
rm -f /tmp/4k_read* 2>/dev/null
if [[ -n "$iops" && "$iops" -gt 0 ]]; then
    if [[ $iops -ge 500000 ]]; then disk_score=10; disk_desc="极速NVMe(${iops} IOPS)"
    elif [[ $iops -ge 200000 ]]; then disk_score=9; disk_desc="高性能NVMe(${iops} IOPS)"
    elif [[ $iops -ge 80000 ]]; then disk_score=8; disk_desc="标准NVMe(${iops} IOPS)"
    elif [[ $iops -ge 30000 ]]; then disk_score=6; disk_desc="优秀SSD(${iops} IOPS)"
    elif [[ $iops -ge 10000 ]]; then disk_score=4; disk_desc="普通SSD(${iops} IOPS)"
    else disk_score=2; disk_desc="慢速盘(${iops} IOPS)"; fi
else
    dd_out=$(dd if=/dev/zero of=/tmp/test bs=1M count=256 conv=fdatasync 2>&1 | tail -1 | awk -F'[ ,]' '{print $(NF-1)}')
    rm -f /tmp/test
    if [[ ${dd_out%.*} -ge 1000 ]]; then disk_score=9; disk_desc="极速(${dd_out}MB/s)"
    elif [[ ${dd_out%.*} -ge 400 ]]; then disk_score=7; disk_desc="高速(${dd_out}MB/s)"
    elif [[ ${dd_out%.*} -ge 150 ]]; then disk_score=5; disk_desc="普通SSD(${dd_out}MB/s)"
    else disk_score=2; disk_desc="慢速(${dd_out}MB/s)"; fi
fi
echo -e "   4K随机读: ${iops:-N/A} IOPS -> ${disk_score}/10 ($disk_desc)"

mem_total=$(free -m | awk '/Mem:/{print $2}')
if [[ $mem_total -ge 16384 ]]; then mem_score=10; mem_desc="超大(≥16G)"
elif [[ $mem_total -ge 8192 ]]; then mem_score=10; mem_desc="大内存(8G)"
elif [[ $mem_total -ge 4096 ]]; then mem_score=9; mem_desc="充足(4G)"
elif [[ $mem_total -ge 2048 ]]; then mem_score=7; mem_desc="够用(2G)"
elif [[ $mem_total -ge 1024 ]]; then mem_score=4; mem_desc="勉强(1G)"
else mem_score=2; mem_desc="极小(<1G)"; fi
echo -e "   内存: ${mem_total}MB -> ${mem_score}/10"

echo -e "\n${YELLOW}📍 [3/7] IP地理位置与类型...${NC}"
geo=$(curl -s --max-time 3 http://ip-api.com/json/)
if [[ -n "$geo" ]]; then
    country=$(echo "$geo" | grep -o '"country":"[^"]*"' | head -1 | cut -d'"' -f4)
    city=$(echo "$geo" | grep -o '"city":"[^"]*"' | head -1 | cut -d'"' -f4)
    isp=$(echo "$geo" | grep -o '"isp":"[^"]*"' | head -1 | cut -d'"' -f4)
    as_info=$(echo "$geo" | grep -o '"as":"[^"]*"' | head -1 | cut -d'"' -f4)
    echo -e "   位置: $country - $city | 运营商: $isp"
    echo -e "   ASN信息: $as_info"
    ip_type="未知"; ip_bonus=0
    country_code=$(echo "$geo" | grep -o '"countryCode":"[^"]*"' | cut -d'"' -f4)
    as_org=$(echo "$as_info" | sed 's/^AS[0-9]* //')
    if echo "$as_org" | grep -qiE "HK|Hong Kong|Japan|Singapore|Korea|Taiwan|China|CN"; then
        if [[ "$country_code" == "HK" || "$country_code" == "JP" || "$country_code" == "SG" || "$country_code" == "KR" || "$country_code" == "TW" || "$country_code" == "CN" ]]; then
            ip_type="原生IP ✓ (ASN注册地与位置一致)"; ip_bonus=2
        else
            ip_type="广播IP (ASN亚洲但位置在非亚洲)"; ip_bonus=0
        fi
    elif echo "$as_org" | grep -qiE "INC|LLC|Corp|US|United States|America"; then
        if [[ "$country_code" == "US" ]]; then
            ip_type="原生IP ✓ (ASN美国且位置在美国)"; ip_bonus=2
        else
            ip_type="广播IP (ASN注册在美国，但IP在当前地区)"; ip_bonus=0
        fi
    else
        reg=$(curl -s --max-time 3 https://ipinfo.io/country 2>/dev/null)
        if [[ -n "$reg" && "$reg" == "$country_code" ]]; then
            ip_type="可能原生 (位置与注册国一致)"; ip_bonus=1
        else
            ip_type="可能广播 (位置与注册国不一致)"; ip_bonus=0
        fi
    fi
    echo -e "   IP类型: $ip_type ($([ $ip_bonus -gt 0 ] && echo "+${ip_bonus}分" || echo "不加分"))"
    if [[ "$country" == "Hong Kong" || "$country" == "Japan" || "$country" == "Singapore" || "$country" == "South Korea" || "$country" == "Taiwan" ]]; then
        base_ip=9; region="亚洲"
    elif [[ "$country" == "United States" ]]; then
        if [[ "$city" == "Los Angeles" || "$city" == "San Jose" || "$city" == "Seattle" ]]; then
            base_ip=7; region="美西"
        else base_ip=5; region="美东/中部"; fi
    elif [[ "$country" == "Germany" || "$country" == "Netherlands" || "$country" == "United Kingdom" ]]; then
        base_ip=3; region="欧洲"
    else base_ip=5; region="其他"; fi
    score_ip=$((base_ip + ip_bonus))
    [[ $score_ip -gt 10 ]] && score_ip=10
    echo -e "   体质: ${score_ip}/10 ($region) [基础分:$base_ip + 类型加分:$ip_bonus]"
else
    score_ip=5; region="未知"
fi

echo -e "\n${YELLOW}🌐 [4/7] 延迟 & TikTok解锁...${NC}"

# --- 多节点延迟测试 ---
echo -e "   ${YELLOW}正在测试到各地域的延迟...${NC}"

# 定义测试节点
declare -A delay_nodes=(
    ["中科院(北京)"]="159.226.8.6"
    ["北京联通(北京)"]="123.123.123.123"
    ["百度(全国CDN)"]="www.baidu.com"
    ["腾讯云(全国Anycast)"]="119.29.29.29"
    ["阿里云(全国Anycast)"]="223.5.5.5"
    ["114DNS(全国)"]="114.114.114.114"
)

all_latencies=()
delay_details=()

for name in "${!delay_nodes[@]}"; do
    ip="${delay_nodes[$name]}"
    ping_result=$(ping -c 1 -W 2 "$ip" 2>/dev/null | grep 'time=' | awk -F 'time=' '{print $2}' | cut -d ' ' -f1)
    
    if [[ -n "$ping_result" ]]; then
        lat=$(printf "%.1f" "$ping_result")
        all_latencies+=("$lat")
        delay_details+=("   ${name}: ${lat}ms")
    else
        delay_details+=("   ${name}: 超时")
    fi
done

echo -e "   ${GREEN}延迟测试结果:${NC}"
for detail in "${delay_details[@]}"; do
    echo -e "   $detail"
done

# --- 计算综合延迟评分 ---
if [[ ${#all_latencies[@]} -gt 0 ]]; then
    sum=0
    for lat in "${all_latencies[@]}"; do
        sum=$(echo "$sum + $lat" | bc)
    done
    lat_int=$(echo "scale=0; $sum / ${#all_latencies[@]}" | bc)
else
    case "$region" in
        "亚洲") lat_int=60 ;;
        "美西") lat_int=180 ;;
        "美东/中部") lat_int=240 ;;
        "欧洲") lat_int=260 ;;
        *) lat_int=200 ;;
    esac
    echo -e "   ${YELLOW}⚠️ 所有节点均超时，使用估算延迟: ${lat_int}ms${NC}"
fi

case "$region" in
    "亚洲")
        if [[ $lat_int -le 60 ]]; then lat_score=10
        elif [[ $lat_int -le 100 ]]; then lat_score=8
        elif [[ $lat_int -le 150 ]]; then lat_score=6
        else lat_score=3; fi ;;
    "美西")
        if [[ $lat_int -le 150 ]]; then lat_score=10
        elif [[ $lat_int -le 180 ]]; then lat_score=8
        elif [[ $lat_int -le 220 ]]; then lat_score=6
        else lat_score=3; fi ;;
    "欧洲"|"美东/中部")
        if [[ $lat_int -le 200 ]]; then lat_score=10
        elif [[ $lat_int -le 250 ]]; then lat_score=8
        elif [[ $lat_int -le 300 ]]; then lat_score=6
        else lat_score=3; fi ;;
    *) lat_score=5 ;;
esac

echo -e "   ${GREEN}综合平均延迟: ${lat_int}ms (区域:$region) -> 得分: ${lat_score}/10${NC}"

# --- TikTok解锁检测（增强版，带超时保护） ---
echo -e "   ${YELLOW}TikTok检测中...${NC}"

# 使用 timeout 强制限制执行时间，避免卡死
tiktok_response=$(timeout 6 curl -sL --max-time 5 -A "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36" "https://www.tiktok.com/" 2>/dev/null)

# 检查 curl 是否超时或失败
if [[ -z "$tiktok_response" ]] || [[ "$tiktok_response" == *"timed out"* ]] || [[ "$tiktok_response" == *"curl: ("* ]]; then
    tiktok_score=2
    tiktok_region="无"
    echo -e "   ${YELLOW}⚠️ TikTok 请求超时或无法访问 (给基础分)${NC}"
else
    # 提取 HTTP 状态码
    tiktok_code=$(echo "$tiktok_response" | head -1 | grep -o "HTTP/.*" | tail -1 | awk '{print $2}' || echo "000")
    if [[ -z "$tiktok_code" || "$tiktok_code" == "000" ]]; then
        tiktok_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "https://www.tiktok.com/" 2>/dev/null)
    fi

    tiktok_score=0
    tiktok_region="无"

    if [[ "$tiktok_code" == "200" ]]; then
        # 尝试提取 region
        tiktok_region=$(echo "$tiktok_response" | grep -oE '"region":"[^"]*"' | head -1 | cut -d'"' -f4)
        if [[ -z "$tiktok_region" || "$tiktok_region" == "null" ]]; then
            tiktok_region=$(echo "$tiktok_response" | grep -oP '(?<=region":")[^"]+' | head -1)
        fi

        if [[ -n "$tiktok_region" && "$tiktok_region" != "null" && "$tiktok_region" != "undefined" ]]; then
            if [[ "$tiktok_region" == "US" || "$tiktok_region" == "JP" || "$tiktok_region" == "HK" || "$tiktok_region" == "KR" ]]; then
                tiktok_score=3
                echo -e "   ${GREEN}✅ TikTok: 解锁 $tiktok_region 区 (+3分)${NC}"
            else
                tiktok_score=1
                echo -e "   ${YELLOW}⚠️ TikTok: 解锁 $tiktok_region 区 (+1分)${NC}"
            fi
        else
            tiktok_score=2
            echo -e "   ${GREEN}✅ TikTok: 可访问 (区域未知)${NC}"
        fi
    else
        tiktok_score=0
        echo -e "   ${RED}❌ TikTok: 无法访问 (HTTP $tiktok_code)${NC}"
    fi
fi

# 确保变量始终有值，防止后续计算报错
[[ -z "$tiktok_score" ]] && tiktok_score=0
[[ -z "$tiktok_region" ]] && tiktok_region="无"


echo -e "\n${YELLOW}🚦 [5/7] 三网回程路由（多节点检测）...${NC}"

# 安装 traceroute（如果未安装）
if ! command -v traceroute &> /dev/null; then
    echo -e "   ${YELLOW}正在安装 traceroute...${NC}"
    apt install traceroute -y >/dev/null 2>&1 || yum install traceroute -y >/dev/null 2>&1
fi

# 检测节点列表（国内三网代表性城市）
declare -A nodes=(
    ["北京电信"]="219.141.140.10"
    ["上海电信"]="202.96.209.133"
    ["广州电信"]="58.60.188.222"
    ["成都电信"]="61.139.2.69"
    ["北京联通"]="202.106.195.68"
    ["上海联通"]="210.22.97.1"
    ["广州移动"]="120.196.165.24"
    ["成都移动"]="211.137.96.205"
)

# 评分变量
cn2_count=0
cn2gt_count=0
cn2gia_count=0
telecom_163=0
unicom_4837=0
mobile_cmi=0
detect_total=0
detect_success=0
route_summary=()

echo -e "   ${YELLOW}正在检测多节点回程路由...${NC}"

for node_name in "${!nodes[@]}"; do
    target_ip="${nodes[$node_name]}"
    # 超时6秒，追踪15跳
    route_output=$(timeout 6 traceroute -T -p 80 -m 15 "$target_ip" 2>/dev/null)
    if [[ -n "$route_output" ]]; then
        detect_success=$((detect_success + 1))
        # 检测线路特征（按优先级从高到低）
        # 1. 检测 CN2 精品线路（最高优先级）
        if echo "$route_output" | grep -qiE "59\.43|CTGNET|CN2"; then
            if echo "$route_output" | grep -qiE "GIA"; then
                cn2gia_count=$((cn2gia_count + 1))
                route_summary+=("${node_name}: CN2 GIA ✅")
            else
                cn2gt_count=$((cn2gt_count + 1))
                route_summary+=("${node_name}: CN2 GT ✅")
            fi
        # 2. 检测联通线路（第二优先级，避免被电信关键词误判）
        elif echo "$route_output" | grep -qiE "AS4837|4837|chinaunicom|CNC"; then
            unicom_4837=$((unicom_4837 + 1))
            route_summary+=("${node_name}: 联通4837")
        # 3. 检测移动线路（第三优先级）
        elif echo "$route_output" | grep -qiE "AS9808|9808|CMI|AS58453|chinamobile|CMCC"; then
            mobile_cmi=$((mobile_cmi + 1))
            route_summary+=("${node_name}: 移动CMI")
        # 4. 检测电信163普通线路（最后匹配）
        elif echo "$route_output" | grep -qiE "202\.97|163"; then
            telecom_163=$((telecom_163 + 1))
            route_summary+=("${node_name}: 电信163")
        else
            route_summary+=("${node_name}: 未知线路")
        fi
        detect_total=$((detect_total + 1))
    fi
done

# 显示检测结果摘要（只显示前5个，避免刷屏）
echo -e "   ${GREEN}检测结果摘要:${NC}"
for ((i=0; i<${#route_summary[@]} && i<6; i++)); do
    echo -e "     ${route_summary[$i]}"
done
if [[ ${#route_summary[@]} -gt 6 ]]; then
    echo -e "     ... 共 ${#route_summary[@]} 个节点"
fi

# 综合评分（满分10分）
if [[ $detect_success -eq 0 ]]; then
    route_score=5
    route_desc="所有节点检测失败"
elif [[ $cn2gia_count -gt 0 ]]; then
    route_score=10
    route_desc="CN2 GIA直连（${cn2gia_count}个节点）"
elif [[ $cn2gt_count -gt 0 ]] && [[ $telecom_163 -eq 0 ]] && [[ $unicom_4837 -eq 0 ]] && [[ $mobile_cmi -eq 0 ]]; then
    route_score=9
    route_desc="纯CN2 GT直连（${cn2gt_count}个节点）"
elif [[ $cn2gt_count -gt 0 ]] && [[ $telecom_163 -gt 0 ]]; then
    route_score=7
    route_desc="混合线路（CN2 GT + 电信163）"
elif [[ $cn2gt_count -gt 0 ]] && [[ $unicom_4837 -gt 0 ]]; then
    route_score=7
    route_desc="混合线路（CN2 GT + 联通4837）"
elif [[ $cn2gt_count -gt 0 ]] && [[ $mobile_cmi -gt 0 ]]; then
    route_score=7
    route_desc="混合线路（CN2 GT + 移动CMI）"
elif [[ $telecom_163 -gt 0 ]] && [[ $unicom_4837 -eq 0 ]] && [[ $mobile_cmi -eq 0 ]]; then
    route_score=6
    route_desc="电信163普通线路"
elif [[ $unicom_4837 -gt 0 ]] && [[ $telecom_163 -eq 0 ]] && [[ $mobile_cmi -eq 0 ]]; then
    route_score=6
    route_desc="联通4837普通线路"
elif [[ $mobile_cmi -gt 0 ]] && [[ $telecom_163 -eq 0 ]] && [[ $unicom_4837 -eq 0 ]]; then
    route_score=6
    route_desc="移动CMI普通线路"
else
    route_score=5
    route_desc="多运营商混合线路"
fi

echo -e "   回程综合评分: ${route_score}/10 (${route_desc})"

echo -e "\n${YELLOW}📶 [6/7] 网络连通与带宽...${NC}"
baidu_code=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 https://www.baidu.com 2>/dev/null)
[[ "$baidu_code" == "200" ]] && { tcp_score=10; tcp_desc="百度通"; } || { tcp_score=3; tcp_desc="百度不通"; }
echo -e "   TCP连通: $tcp_desc -> ${tcp_score}/10"

speed_score=3
speed_desc="测速失败"
upload_mbps=0

if ! command -v speedtest-cli &> /dev/null; then
    echo -e "   ${YELLOW}正在安装 speedtest-cli（约10秒）...${NC}"
    apt install speedtest-cli -y >/dev/null 2>&1 || yum install speedtest-cli -y >/dev/null 2>&1
    if ! command -v speedtest-cli &> /dev/null; then
        apt install python3-pip -y >/dev/null 2>&1
        pip3 install speedtest-cli -q >/dev/null 2>&1
    fi
fi

if command -v speedtest-cli &> /dev/null; then
    echo -e "   ${YELLOW}正在测速（约30秒，测出站带宽）...${NC}"
    st_result=$(timeout 35 speedtest-cli --simple 2>/dev/null)
    if [[ -n "$st_result" ]]; then
        upload_line=$(echo "$st_result" | grep -i "Upload")
        if [[ -n "$upload_line" ]]; then
            upload_raw=$(echo "$upload_line" | awk '{print $2}')
            if [[ -n "$upload_raw" && "$upload_raw" != "0" ]]; then
                upload_mbps=$(printf "%.1f" "$upload_raw")
            fi
        fi
    fi
fi

if [[ -z "$upload_mbps" || "$upload_mbps" == "0" || "$upload_mbps" == "0.0" ]]; then
    echo -e "   ${YELLOW}speedtest 不可用，改用多源下载测速...${NC}"
    max_speed=0
    test_urls=(
        "https://mirrors.tuna.tsinghua.edu.cn/ubuntu-releases/22.04/ubuntu-22.04.5-desktop-amd64.iso.torrent"
        "https://mirrors.ustc.edu.cn/ubuntu-releases/22.04/ubuntu-22.04.5-desktop-amd64.iso.torrent"
        "https://cachefly.cachefly.net/100mb.test"
    )
    for url in "${test_urls[@]}"; do
        sp=$(timeout 6 curl -L -o /dev/null -s -w '%{speed_download}' "$url" 2>/dev/null)
        if [[ -n "$sp" && "$sp" != "0" ]]; then
            mbps=$(echo "scale=2; $sp * 8 / 1000000" | bc 2>/dev/null)
            if (( $(echo "$mbps > $max_speed" | bc -l 2>/dev/null) )); then
                max_speed=$mbps
            fi
        fi
    done
    if [[ -n "$max_speed" && "$max_speed" != "0" ]]; then
        upload_mbps=$max_speed
        speed_desc="入站参考(${upload_mbps}Mbps)"
    else
        upload_mbps=0
        speed_desc="测速失败"
    fi
else
    speed_desc="出站(${upload_mbps}Mbps)"
fi

if [[ -n "$upload_mbps" && "$upload_mbps" != "0" && "$upload_mbps" != "0.0" ]]; then
    if (( $(echo "$upload_mbps >= 80" | bc -l) )); then speed_score=10
    elif (( $(echo "$upload_mbps >= 50" | bc -l) )); then speed_score=9
    elif (( $(echo "$upload_mbps >= 30" | bc -l) )); then speed_score=8
    elif (( $(echo "$upload_mbps >= 15" | bc -l) )); then speed_score=7
    elif (( $(echo "$upload_mbps >= 8" | bc -l) )); then speed_score=5
    elif (( $(echo "$upload_mbps >= 3" | bc -l) )); then speed_score=4
    else speed_score=3
    fi
else
    speed_score=3
fi

echo -e "   带宽: $speed_desc -> ${speed_score}/10"
score_net=$(echo "scale=1; $tcp_score * 0.3 + $lat_score * 0.4 + $speed_score * 0.3" | bc)

echo -e "\n${YELLOW}📺 [7/7] 流媒体解锁...${NC}"
stream_score=0
cc=$(curl -s -o /dev/null -w "%{http_code}" --max-time 4 https://chat.openai.com/ 2>/dev/null)
if [[ "$cc" == "200" ]]; then echo -e "   ${GREEN}ChatGPT: 可访问${NC}"; stream_score=$((stream_score + 4))
elif [[ "$cc" == "302" ]]; then echo -e "   ${YELLOW}ChatGPT: 跳转(可能解)${NC}"; stream_score=$((stream_score + 2))
else echo -e "   ${RED}ChatGPT: 不通${NC}"; fi
yt=$(curl -s -o /dev/null -w "%{http_code}" --max-time 4 https://www.youtube.com/ 2>/dev/null)
if [[ "$yt" == "200" ]]; then echo -e "   ${GREEN}YouTube: 可访问${NC}"; stream_score=$((stream_score + 3))
else echo -e "   ${RED}YouTube: 不通${NC}"; fi
if [[ $stream_score -ge 6 ]]; then score_stream=9; stream_desc="解锁良好"
elif [[ $stream_score -ge 3 ]]; then score_stream=6; stream_desc="部分解锁"
else score_stream=2; stream_desc="基本不解锁"; fi
echo -e "   流媒体: ${score_stream}/10 ($stream_desc)"

hw_score=$(echo "scale=1; ($cpu_score + $disk_score + $mem_score) / 3" | bc)
total=$(echo "scale=2; (${hw_score})*0.20 + (${score_net})*0.30 + (${score_ip})*0.15 + (${score_stream})*0.10 + (${route_score})*0.20 + (${tiktok_score})*0.05" | bc 2>/dev/null)
[[ -z "$total" || "$total" == "0" ]] && total=5.0
final=$(printf "%.1f" "$total")

echo -e "\n${BLUE}=========================================${NC}"
echo -e "${BLUE}         🏆 最终体检报告 (v5.2)       ${NC}"
echo -e "${BLUE}=========================================${NC}"
echo -e "硬件性能 (20%) : ${hw_score}/10  (CPU:$cpu_score 磁盘:$disk_score 内存:$mem_score)"
echo -e "网络质量 (30%) : ${score_net}/10  (延迟:${lat_int}ms | 带宽:$speed_desc)"
echo -e "IP体质   (15%) : ${score_ip}/10  (${region} | ${ip_type})"
echo -e "流媒体   (10%) : ${score_stream}/10"
echo -e "回程直连 (20%) : ${route_score}/10"
echo -e "TikTok   (5%)  : +${tiktok_score}分 (${tiktok_region:-无})"
echo -e "-----------------------------------------"

if (( $(echo "$final >= 8.5" | bc -l) )); then
    echo -e "${GREEN}【总分】: ${final} / 10.0  🏆 S级 (神机)${NC}"
elif (( $(echo "$final >= 7.0" | bc -l) )); then
    echo -e "${GREEN}【总分】: ${final} / 10.0  ✅ A级 (优秀)${NC}"
elif (( $(echo "$final >= 5.5" | bc -l) )); then
    echo -e "${YELLOW}【总分】: ${final} / 10.0  ⚠️ B级 (及格)${NC}"
else
    echo -e "${RED}【总分】: ${final} / 10.0  ❌ C/D级${NC}"
fi
echo -e "${BLUE}=========================================${NC}"
